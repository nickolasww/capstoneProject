# Auth0 SSO Configuration
# Get these values from your Auth0 dashboard at https://manage.auth0.com/
VITE_SSO_TENANT_ID=your-tenant.auth0.com
VITE_SSO_CLIENT_ID=your-client-id
VITE_SSO_CALLBACK_URL=http://localhost:5173/auth/oauth-callback
VITE_SSO_SCOPE=openid profile email
VITE_SSO_AUTHROIZATION_URL=https://your-api-identifier.com

# API Configuration
VITE_API_BASE_URL=http://localhost:3000/api

# App Configuration
VITE_APP_NAME=BAS Website
